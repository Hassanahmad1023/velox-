<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
<meta name="theme-color" content="#0a0a0a"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
<meta name="mobile-web-app-capable" content="yes"/>
<meta name="description" content="VELOX — Real-time GPS speedometer using satellite positioning"/>
<meta name="apple-touch-fullscreen" content="yes"/>
<style>* { -webkit-tap-highlight-color: transparent; -webkit-touch-callout: none; }</style>
<link rel="manifest" href="manifest.json">
<link rel="apple-touch-icon" href="data:image/png;base64,"/>
<title>VELOX — GPS Speed</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Mono:wght@400;700&display=swap');
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;user-select:none;-webkit-user-select:none;}
:root{
  --bg:#0a0a0a;--border:#1e1e1e;--accent:#e8ff47;
  --muted:#333;--text:#f0f0f0;--dim:#555;--red:#ff4444;
  --arc-track:#222;--pivot-bg:#1a1a1a;--pivot-ring:#333;--dir-text:#555;
  --grid-line:rgba(255,255,255,0.013);
}
:root.light{
  --bg:#f4f4f4;--border:#c8c8c8;--accent:#111111;
  --muted:#bbb;--text:#111111;--dim:#777;--red:#cc2222;
  --arc-track:#c8c8c8;--pivot-bg:#e8e8e8;--pivot-ring:#999;--dir-text:#999;
  --grid-line:rgba(0,0,0,0.05);
}
html,body{
  height:100%;background:var(--bg);color:var(--text);
  font-family:'Space Mono',monospace;overflow:hidden;
  -webkit-font-smoothing:antialiased;touch-action:manipulation;
}
body{
  display:flex;flex-direction:column;align-items:center;
  justify-content:center;min-height:100svh;padding:20px;padding-bottom:36px;position:relative;
}
body::before{
  content:'';position:fixed;inset:0;pointer-events:none;
  background-image:linear-gradient(var(--grid-line) 1px,transparent 1px),
    linear-gradient(90deg,var(--grid-line) 1px,transparent 1px);
  background-size:40px 40px;
}
.header{
  position:absolute;top:0;left:0;right:0;
  display:flex;align-items:center;justify-content:space-between;
  padding:18px 20px;
}
.wordmark{
  font-family:'Bebas Neue',sans-serif;font-size:14px;
  letter-spacing:0.35em;color:var(--dim);user-select:none;
}
.sat-badge{
  font-size:9px;letter-spacing:0.15em;color:#000;
  background:#e8ff47;border:1px solid #e8ff47;padding:3px 8px;
  display:flex;align-items:center;gap:5px;
  transition:background 0.3s,border-color 0.3s,color 0.3s;
}
.sat-dot{width:5px;height:5px;border-radius:50%;background:#000;transition:background 0.3s;}
.sat-dot.locked{background:#000;box-shadow:none;}
:root.light .sat-badge{background:#111;border-color:#111;color:#fff;}
:root.light .sat-dot{background:#fff;}
:root.light .sat-dot.locked{background:#e8ff47;}

.gauge-wrap{
  position:relative;
  width:min(320px, 90vw);
  height:min(215px, 60.5vw);
  margin-bottom:-10px;
}
#gauge-svg{width:100%;height:100%;overflow:visible;}
#arc-fill{transition:opacity 0.4s ease;}

.speed-block{text-align:center;line-height:1;margin-bottom:2px;position:relative;}
.speed-num{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(80px,22vw,116px);
  color:var(--text);letter-spacing:-3px;
  transition:color 0.4s ease;display:block;
}
.speed-num.moving{color:var(--accent);text-shadow:0 0 40px rgba(232,255,71,0.2);}
:root.light .speed-num.moving{color:#111;text-shadow:none;}
.speed-num.fast{color:#ff9500;text-shadow:0 0 40px rgba(255,149,0,0.25);}
:root.light .speed-num.fast{color:#cc2222;text-shadow:none;}

.unit-row{
  display:flex;align-items:center;justify-content:center;
  gap:10px;margin-bottom:22px;
}
.unit-label{
  font-size:10px;letter-spacing:0.25em;color:var(--dim);
  cursor:pointer;padding:4px 10px;border:1px solid transparent;
  transition:all 0.2s;user-select:none;
}
.unit-label.active{color:#000;background:#e8ff47;border-color:#e8ff47;font-weight:700;}
:root.light .unit-label.active{background:#111;border-color:#111;color:#fff;}
:root.light .unit-label:hover:not(.active){color:#111;border-color:#999;}
.unit-label:hover:not(.active){color:#888;border-color:var(--border);}

.stats{
  width:100%;display:grid;
  grid-template-columns:1fr 1px 1fr 1px 1fr 1px 1fr;
  border:1px solid var(--border);margin-bottom:16px;
}
.stat-divider{background:var(--border);}
.stat{padding:12px 8px;text-align:center;}
.stat-val{
  font-family:'Bebas Neue',sans-serif;font-size:20px;
  color:var(--text);display:block;line-height:1;margin-bottom:3px;
}
.stat-label{font-size:8px;color:var(--dim);letter-spacing:0.18em;text-transform:uppercase;}

.signal-row{
  width:100%;display:flex;align-items:center;
  gap:10px;margin-bottom:16px;
}
.signal-label{font-size:9px;letter-spacing:0.2em;color:var(--dim);white-space:nowrap;}
.signal-track{flex:1;height:2px;background:var(--muted);overflow:hidden;}
.signal-fill{height:100%;background:var(--accent);transition:width 0.6s ease;width:0%;}
.signal-val{font-size:9px;color:var(--dim);white-space:nowrap;min-width:52px;text-align:right;}

.start-btn{
  width:100%;padding:15px;
  background:#e8ff47;
  border:1px solid #e8ff47;
  color:#000;
  font-family:'Space Mono',monospace;font-size:11px;
  letter-spacing:0.3em;cursor:pointer;
  transition:background 0.25s, color 0.25s, border-color 0.25s;
  text-transform:uppercase;position:relative;
}
:root.light .start-btn{background:#111;border-color:#111;color:#fff;}
:root.light .start-btn.tracking{background:#f4f4f4;border-color:#c8c8c8;color:#111;}
.start-btn:active{transform:scale(0.99);}
.start-btn.tracking{
  background:var(--bg);
  border:1px solid var(--border);
  color:var(--text);
}

.sdot{
  width:6px;height:6px;border-radius:50%;background:var(--dim);
  display:inline-block;margin-right:8px;transition:background 0.3s;vertical-align:middle;
}
.sdot.on{background:var(--accent);box-shadow:0 0 6px var(--accent);animation:pulse 1.5s infinite;}
:root.light .start-btn .sdot.on{background:#e8ff47;box-shadow:0 0 6px #e8ff47;}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.3}}

.error-msg{
  font-size:9px;color:var(--red);letter-spacing:0.15em;
  text-align:center;margin-top:8px;min-height:14px;
}

#install-banner{
  display:none;position:fixed;bottom:0;left:0;right:0;
  background:var(--bg);border-top:1px solid var(--border);
  padding:10px 18px;align-items:center;
  justify-content:space-between;gap:10px;z-index:100;
}
#install-banner.visible{display:flex;}
#install-banner span{font-size:9px;color:var(--dim);letter-spacing:0.15em;}
#install-btn{
  font-family:'Space Mono',monospace;font-size:9px;letter-spacing:0.2em;
  color:#000;background:var(--accent);border:none;padding:7px 12px;cursor:pointer;
}
#dismiss-btn{
  font-family:'Space Mono',monospace;font-size:9px;
  color:var(--dim);background:transparent;border:1px solid var(--border);
  padding:7px 9px;cursor:pointer;
}

@keyframes warnFlash{0%,100%{opacity:0}50%{opacity:1}}
.warn-flash{animation:warnFlash 0.5s ease 3;}

#theme-btn{
  position:fixed;bottom:18px;left:18px;
  font-family:'Space Mono',monospace;font-size:12px;letter-spacing:0.1em;
  color:var(--dim);background:transparent;
  border:1px solid #2a2a2a;padding:8px 10px;
  cursor:pointer;transition:color 0.2s,border-color 0.2s,background 0.2s;
  z-index:50;line-height:1;
}
:root.light #theme-btn{border-color:#bbb;color:#555;}
#theme-btn:hover{color:var(--accent);border-color:var(--accent);}
</style>
</head>
<body>

<div class="header">
  <div class="wordmark">VELOX</div>
  <div class="sat-badge">
    <div class="sat-dot" id="sat-dot"></div>
    <span id="sat-label">NO SAT</span>
  </div>
</div>

<div class="gauge-wrap">
  <svg id="gauge-svg" viewBox="0 0 300 200">
    <path id="arc-track" d="" stroke="#222" stroke-width="3" fill="none" stroke-linecap="butt"/>
    <path id="arc-fill" d="" stroke="#e8ff47" stroke-width="8" fill="none" stroke-linecap="butt"/>
    <g id="ticks"></g>
    <g id="speed-labels" font-family="'Space Mono',monospace" font-size="10" font-weight="bold" text-anchor="middle"></g>
    <line id="needle" x1="150" y1="170" x2="150" y2="170" stroke="#e8ff47" stroke-width="3" stroke-linecap="round"/>
    <circle cx="150" cy="170" r="7" fill="var(--pivot-bg)" stroke="var(--pivot-ring)" stroke-width="1.5"/>
    <circle id="needle-dot" cx="150" cy="170" r="3.5" fill="#e8ff47"/>
    <text id="direction-text" x="150" y="128" text-anchor="middle" dominant-baseline="middle"
      font-family="'Space Mono',monospace" font-size="10" font-weight="700" fill="#888" letter-spacing="3">—</text>
  </svg>
</div>

<div class="speed-block">
  <span class="speed-num" id="speed-display">0</span>
</div>

<div class="unit-row">
  <span class="unit-label active" id="btn-kmh" onclick="setUnit('kmh')">KM/H</span>
  <span class="unit-label"        id="btn-mph" onclick="setUnit('mph')">MPH</span>
  <span class="unit-label"        id="btn-ms"  onclick="setUnit('ms')">M/S</span>
</div>

<div class="stats">
  <div class="stat"><span class="stat-val" id="stat-max">0</span><span class="stat-label">MAX</span></div>
  <div class="stat-divider"></div>
  <div class="stat"><span class="stat-val" id="stat-avg">0</span><span class="stat-label">AVG</span></div>
  <div class="stat-divider"></div>
  <div class="stat"><span class="stat-val" id="stat-dist">0.00</span><span class="stat-label">DIST KM</span></div>
  <div class="stat-divider"></div>
  <div class="stat"><span class="stat-val" id="stat-alt">—</span><span class="stat-label">ALT M</span></div>
</div>

<div class="signal-row">
  <span class="signal-label">GNSS</span>
  <div class="signal-track"><div class="signal-fill" id="signal-fill"></div></div>
  <span class="signal-val" id="signal-val">NO LOCK</span>
</div>

<button class="start-btn" id="start-btn" onclick="toggleTracking()">
  <span class="sdot" id="sdot"></span>START TRACKING
</button>
<div class="error-msg" id="error-msg"></div>

<div id="install-banner">
  <span>ADD VELOX TO HOME SCREEN</span>
  <div style="display:flex;gap:8px">
    <button id="dismiss-btn" onclick="dismissInstall()">✕</button>
    <button id="install-btn" onclick="installApp()">INSTALL</button>
  </div>
</div>

<button id="theme-btn" onclick="toggleTheme()" title="Toggle theme">☀</button>

<script>
// ── Constants ────────────────────────────────────────────────
const CX = 150, CY = 170, R = 138;
const ARC_START = 240, ARC_END = 480, ARC_SWEEP = 240;

// ── State ────────────────────────────────────────────────────
let unit = (() => { try { return localStorage.getItem('velox-unit') || 'kmh'; } catch(e) { return 'kmh'; } })();
let tracking = false, watchId = null;
let maxSpeed = 0, currentSpeedMS = 0;
let deferredPrompt = null;

// ── Distance & time state ────────────────────────────────────
// Uses GPS pos.timestamp (ms) for real elapsed time — no fake tick counting
let lastLat = null, lastLon = null, lastTimestamp = null;
let totalDistKm = 0;
let totalMovingTimeSec = 0; // only time where speed > 0 (moving average)

// ── Smooth display state ─────────────────────────────────────
let displayedSpeed = 0;
let needleSpeed = 0;

const convert = { kmh: v => v*3.6, mph: v => v*2.23694, ms: v => v };
const maxForUnit = { kmh: 220, mph: 140, ms: 60 };
const logicalMax = { kmh: 280, mph: 180, ms: 60 };
const breakpoint = { kmh: 160, mph: 100, ms: 60 };

function speedToFrac(val) {
  const bp = breakpoint[unit];
  const lmax = logicalMax[unit];
  const pmax = maxForUnit[unit];
  const bpFrac = bp / pmax;
  if (val <= bp) {
    return (val / bp) * bpFrac;
  } else {
    const remainArc = 1 - bpFrac;
    const remainVal = lmax - bp;
    return bpFrac + ((val - bp) / remainVal) * remainArc;
  }
}

const gaugeLabels = {
  kmh: [0,20,40,60,80,100,120,140,160,200,240,280],
  mph: [0,20,40,60,80,100,140,180],
  ms:  [0,10,20,30,40,50,60]
};

function toDisplay(ms) { return Math.round(convert[unit](ms)); }

// ── Haversine distance (km) ───────────────────────────────────
function haversine(lat1, lon1, lat2, lon2) {
  const R = 6371;
  const dLat = (lat2 - lat1) * Math.PI / 180;
  const dLon = (lon2 - lon1) * Math.PI / 180;
  const a = Math.sin(dLat/2)**2 +
            Math.cos(lat1 * Math.PI/180) * Math.cos(lat2 * Math.PI/180) *
            Math.sin(dLon/2)**2;
  return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
}

// ── Geometry ─────────────────────────────────────────────────
function polarToXY(deg, r) {
  const rad = (deg - 90) * Math.PI / 180;
  return { x: CX + r*Math.cos(rad), y: CY + r*Math.sin(rad) };
}

function describeArc(startDeg, endDeg) {
  const s = polarToXY(startDeg, R), e = polarToXY(endDeg, R);
  const sweep = endDeg - startDeg;
  const large = sweep > 180 ? 1 : 0;
  return `M ${s.x.toFixed(2)} ${s.y.toFixed(2)} A ${R} ${R} 0 ${large} 1 ${e.x.toFixed(2)} ${e.y.toFixed(2)}`;
}

// ── Build Gauge ───────────────────────────────────────────────
function buildGauge() {
  const fullArc = describeArc(ARC_START, ARC_END);
  const isLight = document.documentElement.classList.contains('light');
  const trackEl = document.getElementById('arc-track');
  trackEl.setAttribute('d', fullArc);
  trackEl.setAttribute('stroke', isLight ? '#ddd' : '#222');
  const needleEl = document.getElementById('needle');
  const dotEl = document.getElementById('needle-dot');
  if (needleEl) needleEl.style.stroke = isLight ? '#111111' : '#e8ff47';
  if (dotEl) dotEl.setAttribute('fill', isLight ? '#111111' : '#e8ff47');

  const fill = document.getElementById('arc-fill');
  fill.setAttribute('d', fullArc);
  const arcLen = Math.PI * R * ARC_SWEEP / 180;
  fill.style.strokeDasharray = arcLen;
  fill.style.strokeDashoffset = arcLen;
  fill._len = arcLen;

  const ticks = document.getElementById('ticks');
  const labels = document.getElementById('speed-labels');
  ticks.innerHTML = ''; labels.innerHTML = '';

  const labelVals = gaugeLabels[unit];
  const tickVals = new Set();
  labelVals.forEach(v => tickVals.add(v));
  for (let i = 0; i < labelVals.length - 1; i++) {
    const mid = (labelVals[i] + labelVals[i+1]) / 2;
    tickVals.add(mid);
  }

  tickVals.forEach(val => {
    const isMajor = labelVals.includes(val);
    const frac = speedToFrac(val);
    const deg = ARC_START + frac * ARC_SWEEP;
    const innerR = isMajor ? R - 14 : R - 6;
    const outerR = R + 5;
    const p1 = polarToXY(deg, innerR), p2 = polarToXY(deg, outerR);
    const line = document.createElementNS('http://www.w3.org/2000/svg','line');
    line.setAttribute('x1', p1.x); line.setAttribute('y1', p1.y);
    line.setAttribute('x2', p2.x); line.setAttribute('y2', p2.y);
    const lIsLight = document.documentElement.classList.contains('light');
    line.setAttribute('stroke', isMajor ? (lIsLight ? '#888' : '#3a3a3a') : (lIsLight ? '#bbb' : '#252525'));
    line.setAttribute('stroke-width', isMajor ? '1.5' : '1');
    ticks.appendChild(line);
  });

  labelVals.forEach(val => {
    const frac = speedToFrac(val);
    const deg = ARC_START + frac * ARC_SWEEP;
    const lp = polarToXY(deg, R - 30);
    const text = document.createElementNS('http://www.w3.org/2000/svg','text');
    text.setAttribute('x', lp.x); text.setAttribute('y', lp.y);
    text.setAttribute('dominant-baseline','middle');
    text.setAttribute('data-val', val);
    text.setAttribute('fill', document.documentElement.classList.contains('light') ? '#111' : '#f0f0f0');
    text.textContent = val;
    labels.appendChild(text);
  });
}

function updateGauge(speedVal) {
  const frac = Math.min(1, speedToFrac(speedVal));
  const fill = document.getElementById('arc-fill');
  const len = fill._len || 1;
  fill.style.strokeDashoffset = len * (1 - frac);
  fill.style.opacity = speedVal > 0 ? '1' : '0';

  const deg = ARC_START + frac * ARC_SWEEP;
  const tip = polarToXY(deg, R - 18);
  const base = polarToXY(deg + 180, 12);
  const needle = document.getElementById('needle');
  needle.setAttribute('x1', base.x.toFixed(2)); needle.setAttribute('y1', base.y.toFixed(2));
  needle.setAttribute('x2', tip.x.toFixed(2));  needle.setAttribute('y2', tip.y.toFixed(2));

  const bp = breakpoint[unit];
  const isLight = document.documentElement.classList.contains('light');
  if (speedVal > bp) {
    const red = isLight ? '#cc2222' : '#ff4444';
    fill.style.stroke = red;
    needle.style.stroke = red;
  } else {
    fill.style.stroke = isLight ? '#111111' : '#e8ff47';
    needle.style.stroke = isLight ? '#111111' : '#e8ff47';
  }
  const ndot = document.getElementById('needle-dot');
  if (ndot) ndot.setAttribute('fill', isLight ? '#111111' : '#e8ff47');

  const labelsEl = document.getElementById('speed-labels');
  if (labelsEl) {
    const lblLight = document.documentElement.classList.contains('light');
    Array.from(labelsEl.children).forEach(el => {
      const labelVal = parseFloat(el.getAttribute('data-val'));
      const t = Math.min(1, Math.max(0, (speedVal - labelVal + 8) / 12));
      if (lblLight) {
        const v = Math.round(0xaa + (0x11 - 0xaa) * t);
        el.setAttribute('fill', `rgb(${v},${v},${v})`);
      } else {
        const r = Math.round(0xf0 + (0xe8 - 0xf0) * t);
        const g = Math.round(0xf0 + (0xff - 0xf0) * t);
        const b = Math.round(0xf0 + (0x47 - 0xf0) * t);
        el.setAttribute('fill', `rgb(${r},${g},${b})`);
      }
    });
  }
}

// ── Smooth Animation Loop ─────────────────────────────────────
let smoothRafId = null;
let lastTickTime = 0;

// Rise fast, fall slowly — asymmetric exponential smoothing
// Alpha closer to 1 = faster response; closer to 0 = slower/smoother
const ALPHA_RISE = 0.10; // ~10 frames to reach target going up
const ALPHA_FALL = 0.04; // ~25 frames to reach target going down (smooth decay)

function startSmoothLoop() {
  if (smoothRafId) return;
  lastTickTime = performance.now();
  function tick(now) {
    const dt = Math.min((now - lastTickTime) / (1000 / 60), 4);
    lastTickTime = now;
    const target = convert[unit](currentSpeedMS);
    const diff = target - needleSpeed;
    // Pick alpha based on direction; scale by dt so framerate-independent
    const alpha = diff > 0 ? ALPHA_RISE : ALPHA_FALL;
    const factor = 1 - Math.pow(1 - alpha, dt);
    if (Math.abs(diff) < 0.05) {
      needleSpeed = target;
    } else {
      needleSpeed += diff * factor;
    }
    displayedSpeed = Math.round(needleSpeed);
    const needleMs = needleSpeed / convert[unit](1);
    if (needleMs > maxSpeed) { maxSpeed = needleMs; refreshStats(); }
    renderDisplay(needleSpeed, displayedSpeed);
    smoothRafId = requestAnimationFrame(tick);
  }
  smoothRafId = requestAnimationFrame(tick);
}

function stopSmoothLoop() {
  if (smoothRafId) { cancelAnimationFrame(smoothRafId); smoothRafId = null; }
}

function renderDisplay(floatSpd, intSpd) {
  const el = document.getElementById('speed-display');
  el.textContent = intSpd;
  el.classList.remove('moving','fast');
  const bp = breakpoint[unit];
  if (floatSpd > bp) el.classList.add('fast');
  else if (floatSpd > 0) el.classList.add('moving');
  updateGauge(floatSpd);
}

// ── Units ─────────────────────────────────────────────────────
function setUnit(u) {
  unit = u;
  try { localStorage.setItem('velox-unit', u); } catch(e){}
  ['kmh','mph','ms'].forEach(id =>
    document.getElementById('btn-'+id).classList.toggle('active', id===u));
  needleSpeed = convert[unit](currentSpeedMS);
  displayedSpeed = Math.round(needleSpeed);
  buildGauge();
  refreshStats();
  renderDisplay(needleSpeed, displayedSpeed);
}

function refreshStats() {
  document.getElementById('stat-max').textContent = toDisplay(maxSpeed);

  // AVG = total distance / total moving time (true travel average speed)
  // totalDistKm in km, totalMovingTimeSec in seconds
  // convert to m/s then to display unit
  const avgMs = totalMovingTimeSec > 0
    ? (totalDistKm * 1000) / totalMovingTimeSec
    : 0;
  document.getElementById('stat-avg').textContent = toDisplay(avgMs);

  document.getElementById('stat-dist').textContent =
    totalDistKm < 10 ? totalDistKm.toFixed(1) : totalDistKm.toFixed(1);
}

// ── Compass ───────────────────────────────────────────────────
const dirs = ['N','NNE','NE','ENE','E','ESE','SE','SSE','S','SSW','SW','WSW','W','WNW','NW','NNW'];
function degToCompass(d) { return dirs[Math.round(d/22.5)%16]; }

// ── Signal ────────────────────────────────────────────────────
function updateSignal(acc) {
  const fill = document.getElementById('signal-fill');
  const val = document.getElementById('signal-val');
  const dot = document.getElementById('sat-dot');
  const lbl = document.getElementById('sat-label');
  if (acc == null) {
    fill.style.width='0%'; val.textContent='NO LOCK';
    dot.classList.remove('locked'); lbl.textContent='NO SAT'; return;
  }
  const pct = Math.max(0, Math.min(100, 100-(acc-3)*(100/97)));
  fill.style.width = pct.toFixed(0)+'%';
  val.textContent = '±'+Math.round(acc)+'m';
  dot.classList.add('locked');
  lbl.textContent = acc < 10 ? 'LOCK ✓' : acc < 30 ? 'WEAK' : 'POOR';
}

// ── GPS ───────────────────────────────────────────────────────
const GNSS_OPTIONS = {
  enableHighAccuracy: true,
  maximumAge: 500,
  timeout: 10000
};

function onPosition(pos) {
  const c = pos.coords;
  currentSpeedMS = (c.speed != null && c.speed >= 0) ? c.speed : 0;

  // ── Distance via Haversine (only add segment if moved meaningfully) ──
  if (lastLat !== null && lastLon !== null) {
    const seg = haversine(lastLat, lastLon, c.latitude, c.longitude);
    if (seg > 0.1) totalDistKm += seg; // ignore < 100m jitter
  }

  // ── Time: use GPS timestamps (milliseconds) for accuracy ────────────
  // Only accumulate time when vehicle is moving (speed > 0.5 m/s ~1.8 km/h)
  // This gives true "moving average" — distance ÷ time spent moving
  if (lastTimestamp !== null && currentSpeedMS > 0.5) {
    const dtSec = (pos.timestamp - lastTimestamp) / 1000;
    // Guard: only accept intervals that make sense (0.5s – 10s)
    if (dtSec > 0.5 && dtSec < 10) {
      totalMovingTimeSec += dtSec;
    }
  }

  lastLat = c.latitude;
  lastLon = c.longitude;
  lastTimestamp = pos.timestamp;

  // Direction
  const dirEl = document.getElementById('direction-text');
  if (c.heading != null && !isNaN(c.heading) && currentSpeedMS > 0.5) {
    dirEl.textContent = degToCompass(c.heading);
    dirEl.setAttribute('fill', document.documentElement.classList.contains('light') ? '#333' : '#aaa');
  } else {
    dirEl.textContent = '—';
    dirEl.setAttribute('fill', document.documentElement.classList.contains('light') ? '#bbb' : '#444');
  }

  if (c.altitude != null)
    document.getElementById('stat-alt').textContent = Math.round(c.altitude);

  updateSignal(c.accuracy);
  refreshStats();
  document.getElementById('error-msg').textContent = '';
}

function onError(err) {
  const msgs = {1:'PERMISSION DENIED',2:'POSITION UNAVAILABLE',3:'GNSS TIMEOUT'};
  document.getElementById('error-msg').textContent = msgs[err.code]||'GNSS ERROR';
  updateSignal(null);
}

function toggleTracking() { tracking ? stopTracking() : startTracking(); }

function startTracking() {
  if (!navigator.geolocation) {
    document.getElementById('error-msg').textContent='GEOLOCATION NOT SUPPORTED'; return;
  }
  tracking = true;
  maxSpeed = 0; currentSpeedMS = 0;
  totalDistKm = 0; totalMovingTimeSec = 0;
  lastLat = null; lastLon = null; lastTimestamp = null;
  needleSpeed = 0; displayedSpeed = 0;
  document.getElementById('direction-text').textContent = '—';
  document.getElementById('direction-text').setAttribute('fill', document.documentElement.classList.contains('light') ? '#bbb' : '#444');
  renderDisplay(0, 0);
  refreshStats();
  document.getElementById('start-btn').innerHTML='<span class="sdot on" id="sdot"></span>STOP TRACKING';
  document.getElementById('start-btn').classList.add('tracking');
  startSmoothLoop();
  watchId = navigator.geolocation.watchPosition(onPosition, onError, GNSS_OPTIONS);
}

function stopTracking() {
  tracking = false;
  if (watchId !== null) { navigator.geolocation.clearWatch(watchId); watchId = null; }
  currentSpeedMS = 0;
  lastLat = null; lastLon = null; lastTimestamp = null;
  document.getElementById('direction-text').textContent = '—';
  document.getElementById('direction-text').setAttribute('fill', document.documentElement.classList.contains('light') ? '#bbb' : '#444');
  const waitForZero = setInterval(() => {
    if (needleSpeed <= 0) {
      needleSpeed = 0; displayedSpeed = 0;
      clearInterval(waitForZero);
      stopSmoothLoop();
    }
  }, 50);
  updateSignal(null);
  document.getElementById('start-btn').innerHTML='<span class="sdot" id="sdot"></span>START TRACKING';
  document.getElementById('start-btn').classList.remove('tracking');
}

// ── PWA Install ───────────────────────────────────────────────
window.addEventListener('beforeinstallprompt', e => {
  e.preventDefault(); deferredPrompt = e;
  try { if (!localStorage.getItem('velox-nodismiss'))
    document.getElementById('install-banner').classList.add('visible');
  } catch(e) {}
});
function installApp() {
  if (!deferredPrompt) return;
  deferredPrompt.prompt();
  deferredPrompt.userChoice.then(() => {
    deferredPrompt=null;
    document.getElementById('install-banner').classList.remove('visible');
  });
}
function dismissInstall() {
  try { localStorage.setItem('velox-nodismiss','1'); } catch(e){}
  document.getElementById('install-banner').classList.remove('visible');
}

// ── Inline Service Worker ─────────────────────────────────────
if ('serviceWorker' in navigator) {
  const sw = "const CACHE = 'velox-v2';\nconst ASSETS = ['/'];\nself.addEventListener('install', e => e.waitUntil(\n  caches.open(CACHE).then(c => c.addAll(ASSETS)).then(() => self.skipWaiting())\n));\nself.addEventListener('activate', e => e.waitUntil(\n  caches.keys().then(keys =>\n    Promise.all(keys.filter(k => k !== CACHE).map(k => caches.delete(k)))\n  ).then(() => self.clients.claim())\n));\nself.addEventListener('fetch', e => e.respondWith(\n  caches.match(e.request).then(cached => cached || fetch(e.request).then(res => {\n    if (res && res.status === 200) {\n      const clone = res.clone();\n      caches.open(CACHE).then(c => c.put(e.request, clone));\n    }\n    return res;\n  }))\n));";
  const blob = new Blob([sw], {type:'application/javascript'});
  navigator.serviceWorker.register(URL.createObjectURL(blob)).catch(()=>{});
}

// ── Wake Lock ─────────────────────────────────────────────────
let wakeLock = null;
async function requestWakeLock() {
  if ('wakeLock' in navigator) {
    try { wakeLock = await navigator.wakeLock.request('screen'); } catch(e) {}
  }
}
async function releaseWakeLock() {
  if (wakeLock) { try { await wakeLock.release(); wakeLock=null; } catch(e){} }
}
document.addEventListener('visibilitychange', async () => {
  if (document.visibilityState==='visible' && tracking) await requestWakeLock();
});

const _startTracking = startTracking;
startTracking = function() { _startTracking(); requestWakeLock(); };
const _stopTracking = stopTracking;
stopTracking = function() { _stopTracking(); releaseWakeLock(); };

// ── Fullscreen ────────────────────────────────────────────────
function requestFullscreen() {
  const el = document.documentElement;
  const req = el.requestFullscreen || el.webkitRequestFullscreen ||
              el.mozRequestFullScreen || el.msRequestFullscreen;
  if (req) req.call(el).catch(() => {});
}
document.addEventListener('click', function enterFS() {
  requestFullscreen();
  document.removeEventListener('click', enterFS);
}, { once: true });
document.addEventListener('fullscreenchange', () => {
  if (!document.fullscreenElement && tracking) requestFullscreen();
});
document.addEventListener('webkitfullscreenchange', () => {
  if (!document.webkitFullscreenElement && tracking) requestFullscreen();
});

// ── Theme ─────────────────────────────────────────────────────
function toggleTheme() {
  const root = document.documentElement;
  const isLight = root.classList.toggle('light');
  try { localStorage.setItem('velox-theme', isLight ? 'light' : 'dark'); } catch(e){}
  document.querySelector('meta[name="theme-color"]').setAttribute('content', isLight ? '#ffffff' : '#0a0a0a');
  document.getElementById('theme-btn').textContent = isLight ? '☾' : '☀';
  buildGauge();
}
(function(){
  try {
    const saved = localStorage.getItem('velox-theme');
    if (saved === 'light') {
      document.documentElement.classList.add('light');
      document.querySelector('meta[name="theme-color"]').setAttribute('content','#ffffff');
      document.getElementById('theme-btn').textContent = '☾';
    }
  } catch(e){}
})();

// ── Init ──────────────────────────────────────────────────────
setUnit(unit);
buildGauge();
renderDisplay(0, 0);
</script>
</body>
</html>
